<!-- First Page for CertTrack Application: in this page will be shown the login page -->
<!-- Vinicius Brito-->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | CertTrack</title>
  <!-- Bootstrap references for CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<!-- Dark green background to match with the temporary logo-->
<body class="d-flex align-items-center" style="min-height:100vh; background-color: #1a3c2e;">
  <div class="container" style="max-width:420px">
    <div class="card shadow">
      <div class="card-body p-4">

        <!-- Logo -->
        <div class="text-center mb-3">
          <img src="/logo.png" alt="CertTrack Logo" style="width: 200px;">
        </div>

        <!-- Subtitle -->
        <p class="text-muted text-center mb-4">Training Compliance System</p>

        <!-- Showing error message if login fails -->
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <!-- Login form - sends data to POST /login route -->
        <form method="POST" action="/login">
          <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" required>
          </div>
          <!-- Submit button -->
          <button type="submit" class="btn w-100 text-white" style="background-color: #1a3c2e;">Login</button>
        </form>

      </div>
    </div>
    <!-- Footer -->
    <p class="text-center mt-3" style="font-size:12px; color: #a8c5b5;">
      CertTrack &copy; 2026 · Your Safety First
    </p>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>