<!-- This form page is responsible for creating or editing construction projects/sites -->
<!-- Vinicius Brito -->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | CertTrack</title>

  <!-- Bootstrap references for CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-light" style="font-family: 'Inter', sans-serif;">

  <!-- Top navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #1a3c2e;">
    <div class="container">
      <a class="navbar-brand" href="/dashboard">
        <img src="/logo.png" alt="CertTrack" style="width: 110px;">
      </a>
      <div class="ms-auto d-flex align-items-center gap-3">
        <a href="/dashboard" class="text-white text-decoration-none">Dashboard</a>
        <a href="/employees" class="text-white text-decoration-none">Employees</a>
        <a href="/projects" class="text-white text-decoration-none fw-bold">Projects</a>
        <span class="text-white">🖊️ <%= user.name %></span>
        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container mt-4" style="max-width: 600px;">

    <!-- Page header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="fw-bold mb-0" style="color: #1a3c2e;"><%= title %></h4>

      <!-- back button-->
      <a href="/projects" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>

    <!-- Form card -->
    <div class="card shadow-sm">
      <div class="card-body p-4">

        <!-- If project exists, we are editing// If not, we are creating a new one -->
        <form method="POST" action="/projects/<%= project ? 'edit/' + project.id : 'create' %>">

          <!-- Project name, mandatory field -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Project Name <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control"
              placeholder="e.g. Dublin Connolly - Section 2"
              value="<%= project ? project.name :'' %>" required>
          </div>

          <!-- Project location/ site address, mandatory field -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Location</label>
            <input type="text" name="location" class="form-control" required
              placeholder="e.g. Dublin, Dublin 01"
              value="<%= project ? project.location : '' %>">

        </div>
          <!-- Project status: active means site is running, closed means finished -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Status <span class="text-danger">*</span></label>
            <select name="status" class="form-select" required>
              <option value="active"<%= project && project.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="closed"<%= project && project.status === 'closed' ? 'selected' : '' %>>Closed</option>
            </select>
          </div>

          <!-- Submit and cancel buttons -->
          <div class="d-flex justify-content-end gap-2 mt-4">
            <a href="/projects" class="btn btn-outline-secondary">Cancel</a>

            <!-- Button text changes depending on if creating or editing -->
            <button type="submit" class="btn text-white" style="background-color: #1a3c2e;">
              <%= project ? 'Save Changes' : 'Add Project' %>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>