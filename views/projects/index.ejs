<!-- This page is for displaying all registered construction sites/projects with options to edit or delete -->
<!-- Vinicius Brito -->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | CertTrack</title>
  <!-- Bootstrap references for CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body class="bg-light" style="font-family: 'Inter', sans-serif;">

  <!-- Top navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #1a3c2e;">
    <div class="container">
      <a class="navbar-brand" href="/dashboard">
        <img src="/logo.png" alt="CertTrack" style="width: 110px;">
      </a>
      <div class="ms-auto d-flex align-items-center gap-3">
        <a href="/dashboard" class="text-white text-decoration-none">Dashboard</a>
        <a href="/employees" class="text-white text-decoration-none">Employees</a>
        <a href="/projects" class="text-white text-decoration-none fw-bold">Projects</a>
        <span class="text-white">🖊️ <%= user.name %></span>
        <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container mt-4">

    <!-- Page header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="fw-bold mb-0" style="color: #1a3c2e;">Construction Projects</h4>
      <a href="/projects/create" class="btn text-white" style="background-color: #1a3c2e;">+ Add Project</a>
    </div>

    <!-- Tables containing projects/site details -->
    <div class="card shadow-sm">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead style="background-color: #1a3c2e; color: white;">
            <tr>
              <th class="px-4 py-3">Project Name</th>
              <th class="py-3">Location</th>
              <th class="py-3">Status</th>
              <th class="py-3 text-center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <!-- If there is no projects registered yet, then show empty message -->
            <% if (projects.length === 0) { %>
              <tr>
                <td colspan="4" class="text-center text-muted py-4">No projects registered yet, please click on "Add Project" to get started.</td>
              </tr>
            <% } else { %>
              <!-- Loop through all projects and display each row -->
              <% projects.forEach(proj => { %>
                <tr>
                  <td class="px-4 py-3 fw-semibold"><%= proj.name %></td>
                  <!-- Showing dash if location is not provided -->
                  <td class="py-3"><%= proj.location || '—' %></td>
                  <!-- Showing badge green for active, grey for closed -->
                  <td class="py-3">
                <span class="badge" style="background-color: <%= proj.status === 'active' ? '#1a3c2e' : '#6c757d' %>;">
                <%= proj.status %>
                </span>
                  </td>
                  <td class="py-3 text-center">
                    <!-- Edit button -->
                    <a href="/projects/edit/<%= proj.id %>" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                    <!-- Delete button -->
                    <form method="POST" action="/projects/delete/<%= proj.id %>" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete <%= proj.name %>?')">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  </td>
                </tr>
              <%})%>
            <% }%>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>